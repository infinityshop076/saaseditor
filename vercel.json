{
  "name": "saas-ia-editor",
  "version": 2,
  "builds": [
    {
      "src": "backend-python/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/edit-image",
      "destination": "/backend-python/main.py"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
